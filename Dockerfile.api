FROM node:18-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY index.js .
RUN mkdir -p public
COPY dashboard-leads.html public/
COPY dashboard.css public/
COPY shared.css public/
COPY relatorio-ia.html public/
COPY contatos.html public/
COPY config.js public/
COPY ferramentas.html public/
COPY chat.html public/
COPY logo.pn[g] public/
EXPOSE 3001
CMD ["node", "index.js"]
